# App Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (Neon Postgres)
# Use pooled connection for serverless (recommended for Vercel)
DATABASE_URL="postgresql://user:password@host.neon.tech/onlysurf?sslmode=require"
# Direct connection for migrations (non-pooled, optional)
DIRECT_URL="postgresql://user:password@host.neon.tech/onlysurf?sslmode=require&connect_timeout=10"

# Firebase Authentication
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com

# Mux Video Processing
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_WEBHOOK_SECRET=your-mux-webhook-secret

# Upstash Redis (Caching)
UPSTASH_REDIS_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe Price IDs
STRIPE_PRICE_COACH_STARTER_MONTHLY=price_coach_starter_monthly
STRIPE_PRICE_COACH_STARTER_ANNUAL=price_coach_starter_annual
STRIPE_PRICE_COACH_PRO_MONTHLY=price_coach_pro_monthly
STRIPE_PRICE_COACH_PRO_ANNUAL=price_coach_pro_annual
STRIPE_PRICE_ACADEMY_MONTHLY=price_academy_monthly
STRIPE_PRICE_ACADEMY_ANNUAL=price_academy_annual
STRIPE_PRICE_PRO_SURFER_MONTHLY=price_pro_surfer_monthly
STRIPE_PRICE_PRO_SURFER_ANNUAL=price_pro_surfer_annual

# Resend Email
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@onlysurf.com

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3001,https://app.onlysurf.com

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_ENABLED=false
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_DEBUG=false

# Session Archive (days before archiving)
SESSION_ARCHIVE_DAYS=30
