{
    "version": 2,
    "builds": [
        {
            "src": "src/serverless.ts",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/(.*)",
            "dest": "src/serverless.ts"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    },
    "regions": [
        "fra1"
    ]
}